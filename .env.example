# OpenAI (server only — never NEXT_PUBLIC_)
OPENAI_API_KEY=sk-...
# Optional: defaults to gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# Firebase Admin (Firestore). Recommended on Vercel: ONE variable with the full JSON (minify to one line).
# Firebase Console → Project settings → Service accounts → Generate new private key → paste entire file:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...",...}

# Alternative: three separate variables (private key: use \n for line breaks inside quotes).
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional: lock POST /api/review to your site origin (e.g. https://sandboxbd.com). Leave unset for local dev.
# APP_ORIGIN=https://sandboxbd.com

# Optional: still use an external review API instead of /api/review (legacy)
# NEXT_PUBLIC_API_URL=https://api.example.com

# Firebase Web SDK (client — safe to expose; restrict domains in Firebase Console)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional; required for Analytics
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
