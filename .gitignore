# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
Thumbs.db
*.pem
*.log

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# environment & secrets (keep .env.example committed as the template)
.env
.env.*
!.env.example
.envrc

# Firebase / GCP service account keys (never commit)
*-firebase-adminsdk-*.json
.firebase/
firebase-debug.log*
firestore-debug.log*
ui-debug.log*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# eslint
.eslintcache

# IDE / OS (local only)
.idea/
*.swp
*.swo
